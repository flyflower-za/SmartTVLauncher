<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="30dp"
    android:background="@drawable/premium_bg">

    <!-- 顶部标题栏 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="微鲸极简桌面"
            android:textColor="@color/text_main"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true" />

        <!-- 顶部状态栏：包含时间、日期、分割线和 WiFi 指示器 -->
        <LinearLayout
            android:id="@+id/status_bar_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingLeft="14dp"
            android:paddingRight="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:background="@drawable/status_bar_bg">

            <!-- 时间/日期 -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="right"
                android:layout_marginRight="12dp">
                
                <TextView
                    android:id="@+id/tv_clock_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:00"
                    android:textColor="@color/text_main"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:includeFontPadding="false" />
                
                <TextView
                    android:id="@+id/tv_clock_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2026年7月18日 星期六"
                    android:textColor="@color/text_sub"
                    android:textSize="10sp"
                    android:layout_marginTop="2dp"
                    android:includeFontPadding="false" />
            </LinearLayout>

            <!-- 分割线 -->
            <View
                android:layout_width="1dp"
                android:layout_height="24dp"
                android:background="#33ffffff"
                android:layout_marginRight="12dp" />

            <!-- Wi-Fi 状态指示图，仅展示状态 -->
            <ImageView
                android:id="@+id/iv_wifi_status"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:focusable="false"
                android:clickable="false"
                android:padding="2dp"
                android:src="@drawable/wifi_online" />
        </LinearLayout>

    </RelativeLayout>

    <!-- 直达与信号源行标签 -->
    <TextView
        android:id="@+id/tv_source_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="直达与信号源 (长按系统设置可一键恢复原厂桌面组件)"
        android:textColor="@color/text_sub"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:id="@+id/layout_source_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="25dp">

        <!-- HDMI 1 Card -->
        <LinearLayout
            android:id="@+id/card_hdmi1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginRight="10dp"
            android:background="@drawable/card_selector"
            android:focusable="true"
            android:clickable="true"
            android:orientation="vertical"
            android:padding="18dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="130dp">
                <TextView
                    android:id="@+id/tv_status_hdmi1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● 已连接"
                    android:textColor="#10b981"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentTop="true" />
                <TextView
                    android:id="@+id/star_hdmi1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 默认"
                    android:textColor="@color/star_color"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_alignParentRight="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hdmi1"
                    android:textColor="@color/text_main"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_alignParentBottom="true" />
            </RelativeLayout>
        </LinearLayout>

        <!-- HDMI 2 Card -->
        <LinearLayout
            android:id="@+id/card_hdmi2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginRight="10dp"
            android:background="@drawable/card_selector"
            android:focusable="true"
            android:clickable="true"
            android:orientation="vertical"
            android:padding="18dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="130dp">
                <TextView
                    android:id="@+id/tv_status_hdmi2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● 已连接"
                    android:textColor="#10b981"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentTop="true" />
                <TextView
                    android:id="@+id/star_hdmi2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 默认"
                    android:textColor="@color/star_color"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="visible"
                    android:layout_alignParentRight="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/hdmi2"
                    android:textColor="@color/text_main"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_alignParentBottom="true" />
            </RelativeLayout>
        </LinearLayout>

        <!-- AV Card -->
        <LinearLayout
            android:id="@+id/card_av"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginRight="10dp"
            android:background="@drawable/card_selector"
            android:focusable="true"
            android:clickable="true"
            android:orientation="vertical"
            android:padding="18dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="130dp">
                <TextView
                    android:id="@+id/tv_status_av"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="● 无信号"
                    android:textColor="#9ca3af"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentTop="true" />
                <TextView
                    android:id="@+id/star_av"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ 默认"
                    android:textColor="@color/star_color"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    android:layout_alignParentRight="true" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/av"
                    android:textColor="@color/text_main"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_alignParentBottom="true" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Settings Card -->
        <LinearLayout
            android:id="@+id/card_settings"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/card_selector"
            android:focusable="true"
            android:clickable="true"
            android:orientation="vertical"
            android:padding="18dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="130dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings"
                    android:textColor="@color/text_main"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:layout_alignParentBottom="true" />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 应用抽屉行 -->
    <TextView
        android:id="@+id/tv_apps_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="已安装应用 (长按遥控确认键可自定义更换固定)"
        android:textColor="@color/text_sub"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:id="@+id/apps_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp" />

    <!-- 底部倒计时容器 -->
    <LinearLayout
        android:id="@+id/countdown_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal|bottom">

        <TextView
            android:id="@+id/tv_countdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="将在 5 秒后自动直达开机默认源"
            android:textColor="@color/text_sub"
            android:textSize="13sp"
            android:layout_marginBottom="8dp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="280dp"
            android:layout_height="4dp"
            android:max="100"
            android:progress="100" />
    </LinearLayout>

</LinearLayout>
